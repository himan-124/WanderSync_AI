# Amap Web Service Key (Required)
AMAP_API_KEY=

# Amap Web JS API Key (For frontend maps, optional)
AMAP_JS_KEY=

# Amap JS API Security Code securityJsCode (Matches JS Key, optional)
AMAP_JS_SECURITY_CODE=

# LLM Provider (Optional, default "deepseek", supports "deepseek", "doubao")
# LLM_PROVIDER=deepseek

# DeepSeek API Key (Required if using DeepSeek provider)
DEEPSEEK_API_KEY=

# DeepSeek Model (Optional, default deepseek-v4-flash)
# DEEPSEEK_MODEL=deepseek-v4-flash

# Doubao API Key (Required if using Doubao provider)
# DOUBAO_API_KEY=

# Doubao Model (Optional, default doubao-pro-4k)
# DOUBAO_MODEL=doubao-pro-4k

# Redis Cache (Optional, disables caching if not configured)
REDIS_URL=redis://localhost:6379/0

# HTTP Proxy (Optional)
# HTTPS_PROXY=http://127.0.0.1:7890

# LangSmith Tracing (Optional, for viewing Agent traces at smith.langchain.com)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__your_key
# LANGCHAIN_PROJECT=floattrip-dev
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
